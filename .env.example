# =============================================================================
# Farukh Saifi Portfolio — Environment Variables
# Copy to .env.local for local development.
# Set these in Vercel (or .env.production) for production deployments.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Public site URL (used for Spotify OAuth redirect, OG tags, RSS)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Spotify (required for Now Playing)
# Create an app at https://developer.spotify.com/dashboard
# Redirect URI: {NEXT_PUBLIC_BASE_URL}/spotify-success
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# MongoDB (required for Spotify token storage)
# Uses the syncapp database / credentials collection
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/syncapp

# -----------------------------------------------------------------------------
# SyncApp blog integration (server-side only)
# Fetches published posts from https://sync-app-server.vercel.app/api
# See SyncApp API Postman collection: Auth → Login, Posts → Get Posts
# -----------------------------------------------------------------------------

# API base URL (optional — defaults to production URL in prod, localhost:9000 in dev)
# SYNCAPP_API_URL=https://sync-app-server.vercel.app/api

# Option A: Bearer token from Postman {{token}} or SyncApp login response
# SYNCAPP_API_TOKEN=

# Option B: Login credentials (POST /auth/login)
# SYNCAPP_EMAIL=your@email.com
# SYNCAPP_PASSWORD=your_password

# -----------------------------------------------------------------------------
# Admin / route protection (optional)
# Used by /api/authenticate for password-protected pages (see once-ui.config.ts)
# Note: RouteGuard currently sends password only; email defaults to ADMIN_EMAIL
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@farukh.me
ADMIN_PASSWORD=your-admin-password
